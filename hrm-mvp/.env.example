# Docker Compose SMTP settings for email verification.
# Copy this file to .env in the project root before running docker compose.

FRONTEND_URL=http://localhost:5173

# Leave SMTP_HOST empty for demo mode: backend logs will contain verification links.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@hermes.local
SMTP_USE_TLS=true

# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_google_app_password
# SMTP_FROM=HERMES <your_email@gmail.com>
# SMTP_USE_TLS=true
