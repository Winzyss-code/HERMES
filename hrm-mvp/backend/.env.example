# Database
DATABASE_URL=postgresql://hermes:hermes_password@localhost:5432/hermes

# JWT
JWT_SECRET=change-this-secret-for-production
JWT_ALGORITHM=HS256

# Frontend URL used in email verification links
FRONTEND_URL=http://localhost:5173

# SMTP email verification
# Leave SMTP_HOST empty for local demo mode: verification links are printed in backend logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@hermes.local
SMTP_USE_TLS=true

# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_google_app_password
# SMTP_FROM=HERMES <your_email@gmail.com>
# SMTP_USE_TLS=true
